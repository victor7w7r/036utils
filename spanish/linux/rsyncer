function whichverify() {
	stat=$(which "$1" 2>&1)
	if [[ "$stat" =~ ^which:* ]]; then 
		return 1
	else
		return 0
	fi
}

function syncer {

	SOURCEREADY=""
	DESTREADY=""

    if [[ "$SOURCE" =~ .*\/$ ]]; then
        SOURCEREADY="$SOURCE"
    else
        SOURCEREADY="$SOURCE/"
    fi

    if [[ "$DEST" =~ .*\/$ ]]; then
        DESTREADY="$DEST"
    else
        DESTREADY="$DEST/"
    fi

	clear
	echo -e "=============== EMPEZAR RSYNC =============== \n" 
	echo "SOURCE: $SOURCEREADY"
	echo -e "DESTINATION: $DESTREADY \n"
	$SUDO rsync -axHAWXS --numeric-ids --info=progress2 "$SOURCEREADY" "$DESTREADY"

	echo -e "\n =============== OK =============== \n" 
	echo -e "Listo!\n"
	exit 0
}

function validator() {

	if [ "$1" == "source" ]; then
		if [ "$2" != "" ]; then
			if [ -d "$2" ]; then
				SOURCE="$2"
				destiaction
				return 0
			else
				clear
    			echo "ERROR: El directorio \"$2\" no existe"
        	    read -r -p "Presione Enter para continuar..."
        		sourceaction
				return 0
			fi
		else
			exit 0;
		fi
	elif [ "$1" == "dest" ]; then
		if [ "$2" != "" ]; then
			if [ -d "$2" ]; then
				DEST="$2"
				syncer
				return 0
			else
				clear
    			echo "ERROR: El directorio \"$2\" no existe"
        		read -r -p "Presione Enter para continuar..."
        		destiaction
				return 0
			fi
		else
			sourceaction
		fi
	else
		exit 0;
	fi
	
}

function sourceaction {

    dialog --title "036 rsyncer" \
    --backtitle "036 Creative Studios" \
    --inputbox "Por favor escriba su directorio de origen" 8 80 2>"$SOURCETEMP"

    RESPONSE=$?
    DATA=$(<$SOURCETEMP)

    case $RESPONSE in
    0) 
        validator "source" "${DATA}" ;;
    1) 
        clear; exit 0  
        return;;
    255) 
        clear; exit 0
        return;;
    esac

}

function destiaction {

	RESPONSE=0
	DATA=0

	dialog --title "036 rsyncer" \
	--backtitle "036 Creative Studios" \
	--inputbox "Por favor escriba su directorio de destino" 8 80 2>"$DESTTEMP"

	RESPONSE=$?
	DATA=$(<$DESTTEMP)

	case $RESPONSE in
	0) 
		validator "dest" "${DATA}" ;;
	1) 
		clear; sourceaction break;;
	255) 
		clear; sourceaction break;;
	esac

}

function verify {

    OPERATING=$(uname -o)
	SELECTOR=""

	if [ "$OPERATING" != "GNU/Linux" ]; then
		echo "ERROR: Este sistema no es GNU/Linux, saliendo"
		exit 0
	fi

	SELECTOR="rsync"
	whichverify "$SELECTOR"
	local res=$?

	if [ $res -eq 1 ]; then
		echo "ERROR: El ejecutable de rsync, no se encuentra en el sistema, por favor instalalo"
		exit 0
	fi

	echo "Todo ok!"

	START=$(date +%s)
	CHARS="/-\|"

	while [[ $(($(date +%s) - START)) -lt 2 ]]; do
		for (( i=0; i<${#CHARS}; i++ )); do
			sleep 0.08
			echo -en "${CHARS:$i:1}" "\r"
		done
	done
	clear

    sourceaction
}

core

[ -f $SOURCETEMP ] && rm $SOURCETEMP
[ -f $DESTTEMP ] && rm $DESTTEMP