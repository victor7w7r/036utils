#!/usr/bin/env bash

SUDO=
if [ "$EUID" != "0" ]; then
	if  [ -e /usr/bin/sudo ] || [ -e /bin/sudo ]; then
		SUDO=sudo
	else
		echo "ERROR: En este sistema no existe el binario de superusuario."
		exit 0
	fi
fi

rm /tmp/source.sh* 2> /dev/null
rm /tmp/dest.sh* 2> /dev/null
SOURCETEMP=/tmp/source.sh.$$
DESTTEMP=/tmp/dest.sh.$$

SOURCE=""
DEST=""

function cleanup { rm "$SOURCE"; rm "$DEST"; exit; }

trap cleanup; SIGHUP SIGINT SIGTERM

